# Bu dosyayı .env olarak kopyalayın (sadece yerel test içindir).
# GitHub Actions için aşağıdaki üç değeri repo'nun Secrets bölümüne ekleyin:
#   Settings → Secrets and variables → Actions → New repository secret

# Gönderici Gmail adresi
EMAIL_USERNAME=

# Gmail "Uygulama Şifresi" — normal Gmail şifreniz değil!
# Nasıl oluşturulur: Google Hesabı → Güvenlik → 2 Adımlı Doğrulama açık olmalı
#   → Uygulama şifreleri → Uygulama: Mail, Cihaz: Diğer → Oluştur
EMAIL_APP_PASSWORD=

# Rapor e-postasının gönderileceği adres (kendi adresiniz olabilir)
EMAIL_TO=
